    "# -------------------------\n",
    "# 2. KNN Classifier\n",
    "# -------------------------\n",
    "knn_clf = KNeighborsClassifier(n_neighbors=5)  # you can tune k\n",
    "knn_clf.fit(images_scaled, labels)\n",
    "y_pred_knn = knn_clf.predict(X_test_scaled)\n",
    "\n",
