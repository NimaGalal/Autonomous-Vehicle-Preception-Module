    "def pixel_stats(X):\n",
    "\n",
    "  flatten_img = X.flatten()\n",
    "  Stats = {\n",
    "      'mean': [np.mean(flatten_img)],\n",
    "      'median': [np.median(flatten_img)],\n",
    "      'std': [np.std(flatten_img)],\n",
    "      'max': [np.max(flatten_img)],\n",
    "      'min': [np.min(flatten_img)],\n",
    "  }\n",
    "  return pd.DataFrame(Stats)"
   ]
  },
